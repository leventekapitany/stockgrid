{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "stock",
  "main": ".output/server/index.mjs",
  "compatibility_date": "2026-05-11",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".output/public"
  },
  "no_bundle": true,
  "rules": [
    {
      "type": "ESModule",
      "globs": ["**/*.mjs", "**/*.js"]
    }
  ]
}
