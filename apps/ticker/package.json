{
  "name": "@stock/ticker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env bun --watch src/index.ts",
    "start": "pnpm with-env bun src/index.ts",
    "start:prod": "bun src/index.ts",
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@stock/api": "workspace:*",
    "@stock/auth": "workspace:*",
    "@stock/db": "workspace:*",
    "@stock/validators": "workspace:*",
    "@trpc/server": "catalog:",
    "superjson": "2.2.3",
    "ws": "^8.18.0",
    "yahoo-finance2": "^3.14.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@stock/eslint-config": "workspace:*",
    "@stock/prettier-config": "workspace:*",
    "@stock/tsconfig": "workspace:*",
    "@types/bun": "^1.1.13",
    "@types/node": "catalog:",
    "@types/ws": "^8.5.13",
    "dotenv-cli": "^10.0.0",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@stock/prettier-config"
}
