# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to \`.env\`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# The database URL is used to connect to your Supabase database.
POSTGRES_URL="postgresql://db.example.com:5432/postgres"


# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET=''
AUTH_URL='http://localhost:3000'

# Google OAuth provider for the web app.
# Add these redirect URIs in Google Cloud:
# - http://localhost:3000/api/auth/callback/google
# - https://stockgrid.app/api/auth/callback/google
AUTH_GOOGLE_ID=''
AUTH_GOOGLE_SECRET=''

# Live ticker (apps/ticker) — Bun WebSocket server. Public so the browser can connect.
VITE_TICKER_WS_URL='ws://localhost:4001'
TICKER_PORT=4001

# Google Gemini API key for AI stock search (apps/tanstack-start, server-side only).
# @see https://aistudio.google.com/apikey
GEMINI_API_KEY=''
